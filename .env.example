# Resend Email Configuration
# Sign up at https://resend.com and add your domain, then paste your API key here
RESEND_API_KEY=re_xxxxxxxxxxxx

# The "from" address for outgoing emails (must be a domain verified in Resend)
EMAIL_FROM="LA SOCIEDAD" <noreply@la-sociedad.club>

# Where booking and contact form notifications are sent
NOTIFICATION_EMAIL=hello@la-sociedad.club
